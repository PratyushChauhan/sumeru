{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sumeru",
  "version": "0.1.0",
  "identifier": "com.sumeru.app",
  "build": {
    "beforeDevCommand": "npm run docs:build && npm run dev",
    "beforeBuildCommand": "npm run docs:build && npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "sumeru",
        "width": 960,
        "height": 720,
        "decorations": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/docs"]
  }
}
